    "import tkinter as tk\n",
    "from tkinter import ttk, messagebox\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg\n",
    "\n",
    "# -----------------------------------------\n",
    "# STEP 1: BACKEND LOGIC (The Algorithms)\n",
    "# -----------------------------------------\n",
    "\n",
    "def evaluate_function(expression, x_val):\n",
    "    \"\"\"Safely evaluates the mathematical string input by the user.\"\"\"\n",
    "    safe_dict = {k: v for k, v in np.__dict__.items() if not k.startswith('_')}\n",
    "    safe_dict['x'] = x_val\n",
    "    try:\n",
    "        return eval(expression, {\"__builtins__\": None}, safe_dict)\n",
    "    except Exception as e:\n",
    "        raise ValueError(f\"Invalid function or math error: {e}\")\n",
    "\n",
    "def get_derivative(expression, x_val, h=1e-5):\n",
    "    \"\"\"Calculates numerical derivative for Newton-Raphson.\"\"\"\n",
    "    return (evaluate_function(expression, x_val + h) - evaluate_function(expression, x_val - h)) / (2 * h)\n",
    "\n",
    "# --- Updated Algorithms to store geometric data ---\n",
    "\n",
    "def bisection(expr, xl, xu, tol, max_iter):\n",
    "    hist = []\n",
    "    fl = evaluate_function(expr, xl)\n",
    "    fu = evaluate_function(expr, xu)\n",
    "    \n",
    "    if fl * fu > 0:\n",
    "        raise ValueError(\"f(Lower) and f(Upper) must have opposite signs.\")\n",
    "        \n",
    "    for i in range(max_iter):\n",
    "        xr = (xl + xu) / 2\n",
    "        fxr = evaluate_function(expr, xr)\n",
    "        err = abs(xu - xl) / 2\n",
    "        # Store bracket for visualization: (iter, xr, fxr, err, xl, xu)\n",
    "        hist.append((i+1, xr, fxr, err, xl, xu))\n",
    "        \n",
    "        if err < tol or fxr == 0:\n",
    "            return xr, hist\n",
    "            \n",
    "        if fl * fxr < 0:\n",
    "            xu = xr\n",
    "        else:\n",
    "            xl = xr\n",
    "            fl = fxr\n",
    "    return xr, hist\n",
    "\n",
    "def false_position(expr, xl, xu, tol, max_iter):\n",
    "    hist = []\n",
    "    fl = evaluate_function(expr, xl)\n",
    "    fu = evaluate_function(expr, xu)\n",
    "    \n",
    "    if fl * fu > 0:\n",
    "        raise ValueError(\"f(Lower) and f(Upper) must have opposite signs.\")\n",
    "        \n",
    "    xr_prev = xl\n",
    "    for i in range(max_iter):\n",
    "        xr = xu - (fu * (xl - xu)) / (fl - fu)\n",
    "        fxr = evaluate_function(expr, xr)\n",
    "        err = abs(xr - xr_prev)\n",
    "        # Store bracket points for visualization: (iter, xr, fxr, err, xl, fl, xu, fu)\n",
    "        hist.append((i+1, xr, fxr, err, xl, fl, xu, fu))\n",
    "        \n",
    "        if err < tol or fxr == 0:\n",
    "            return xr, hist\n",
    "            \n",
    "        if fl * fxr < 0:\n",
    "            xu = xr\n",
    "            fu = fxr\n",
    "        else:\n",
    "            xl = xr\n",
    "            fl = fxr\n",
    "        xr_prev = xr\n",
    "    return xr, hist\n",
    "\n",
    "def newton_raphson(expr, x0, tol, max_iter):\n",
    "    hist = []\n",
    "    xi = x0\n",
    "    for i in range(max_iter):\n",
    "        fxi = evaluate_function(expr, xi)\n",
    "        dfxi = get_derivative(expr, xi)\n",
    "        \n",
    "        if dfxi == 0:\n",
    "            raise ValueError(\"Derivative is zero. Method fails.\")\n",
    "            \n",
    "        xi_next = xi - (fxi / dfxi)\n",
    "        err = abs(xi_next - xi)\n",
    "        # Store point and slope for visualization: (iter, xi_next, f(xi_next), err, xi, fxi, dfxi)\n",
    "        hist.append((i+1, xi_next, evaluate_function(expr, xi_next), err, xi, fxi, dfxi))\n",
    "        \n",
    "        if err < tol:\n",
    "            return xi_next, hist\n",
    "        xi = xi_next\n",
    "    return xi, hist\n",
    "\n",
    "def secant(expr, x0, x1, tol, max_iter):\n",
    "    hist = []\n",
    "    fx0 = evaluate_function(expr, x0)\n",
    "    fx1 = evaluate_function(expr, x1)\n",
    "    \n",
    "    for i in range(max_iter):\n",
    "        if fx1 - fx0 == 0:\n",
    "            raise ValueError(\"Division by zero in Secant method.\")\n",
    "            \n",
    "        x_next = x1 - (fx1 * (x1 - x0)) / (fx1 - fx0)\n",
    "        err = abs(x_next - x1)\n",
    "        # Store two points for visualization: (iter, x_next, f(x_next), err, x0, fx0, x1, fx1)\n",
    "        hist.append((i+1, x_next, evaluate_function(expr, x_next), err, x0, fx0, x1, fx1))\n",
    "        \n",
    "        if err < tol:\n",
    "            return x_next, hist\n",
    "        \n",
    "        # Update points for next iteration\n",
    "        x0, x1 = x1, x_next\n",
    "        fx0, fx1 = fx1, evaluate_function(expr, x_next)\n",
    "    return x_next, hist\n",
    "\n",
    "\n",
    "# -----------------------------------------\n",
    "# STEP 2 & 3: FRONTEND LAYOUT & INTEGRATION\n",
    "# -----------------------------------------\n",
    "\n",
    "class NumericalMethodsApp:\n",
    "    def __init__(self, root):\n",
    "        self.root = root\n",
    "        self.root.title(\"Numerical Methods: Root Finder with Geometric Interpretation\")\n",
    "        self.root.geometry(\"1100x650\")\n",
    "        \n",
    "        # --- Top Frame (Inputs) ---\n",
    "        self.frame_top = ttk.Frame(self.root, padding=10)\n",
    "        self.frame_top.pack(side=tk.TOP, fill=tk.X)\n",
    "        \n",
    "        # Row 0\n",
    "        ttk.Label(self.frame_top, text=\"Function f(x):\").grid(row=0, column=0, padx=5, pady=5, sticky=tk.W)\n",
    "        self.entry_func = ttk.Entry(self.frame_top, width=30)\n",
    "        self.entry_func.grid(row=0, column=1, padx=5, pady=5)\n",
    "        self.entry_func.insert(0, \"x**2 - 3\")\n",
    "        \n",
    "        ttk.Label(self.frame_top, text=\"Method:\").grid(row=0, column=2, padx=5, pady=5, sticky=tk.W)\n",
    "        self.method_var = tk.StringVar(value=\"Newton-Raphson\")\n",
    "        self.combo_method = ttk.Combobox(self.frame_top, textvariable=self.method_var, state=\"readonly\",\n",
    "                                         values=[\"Bisection\", \"False Position\", \"Newton-Raphson\", \"Secant\"])\n",
    "        self.combo_method.grid(row=0, column=3, padx=5, pady=5)\n",
    "        self.combo_method.bind(\"<<ComboboxSelected>>\", self.toggle_inputs)\n",
    "        \n",
    "        # Row 1\n",
    "        ttk.Label(self.frame_top, text=\"Lower / x0:\").grid(row=1, column=0, padx=5, pady=5, sticky=tk.W)\n",
    "        self.entry_xl = ttk.Entry(self.frame_top, width=15)\n",
    "        self.entry_xl.grid(row=1, column=1, padx=5, pady=5, sticky=tk.W)\n",
    "        self.entry_xl.insert(0, \"2\")\n",
    "        \n",
    "        ttk.Label(self.frame_top, text=\"Upper / x1:\").grid(row=1, column=2, padx=5, pady=5, sticky=tk.W)\n",
    "        self.entry_xu = ttk.Entry(self.frame_top, width=15)\n",
    "        self.entry_xu.grid(row=1, column=3, padx=5, pady=5, sticky=tk.W)\n",
    "        self.entry_xu.insert(0, \"3\")\n",
    "        self.toggle_inputs() # Set initial state\n",
    "\n",
    "        # Row 2\n",
    "        ttk.Label(self.frame_top, text=\"Tolerance:\").grid(row=2, column=0, padx=5, pady=5, sticky=tk.W)\n",
    "        self.entry_tol = ttk.Entry(self.frame_top, width=15)\n",
    "        self.entry_tol.grid(row=2, column=1, padx=5, pady=5, sticky=tk.W)\n",
    "        self.entry_tol.insert(0, \"0.0001\")\n",
    "        \n",
    "        ttk.Label(self.frame_top, text=\"Max Iterations:\").grid(row=2, column=2, padx=5, pady=5, sticky=tk.W)\n",
    "        self.entry_iter = ttk.Entry(self.frame_top, width=15)\n",
    "        self.entry_iter.grid(row=2, column=3, padx=5, pady=5, sticky=tk.W)\n",
    "        self.entry_iter.insert(0, \"100\")\n",
    "        \n",
    "        self.btn_calc = ttk.Button(self.frame_top, text=\"Calculate\", command=self.calculate)\n",
    "        self.btn_calc.grid(row=0, column=4, rowspan=3, padx=20, pady=5, ipadx=15, ipady=15)\n",
    "        \n",
    "        # --- Bottom Frame (Table & Graph) ---\n",
    "        self.frame_bottom = ttk.Frame(self.root, padding=10)\n",
    "        self.frame_bottom.pack(side=tk.BOTTOM, fill=tk.BOTH, expand=True)\n",
    "        \n",
    "        # Table (Left)\n",
    "        self.frame_table = ttk.Frame(self.frame_bottom)\n",
    "        self.frame_table.pack(side=tk.LEFT, fill=tk.Y)\n",
    "        \n",
    "        columns = (\"Iter\", \"x_approx\", \"f(x_approx)\", \"Error\")\n",
    "        self.tree = ttk.Treeview(self.frame_table, columns=columns, show=\"headings\", height=15)\n",
    "        for col in columns:\n",
    "            self.tree.heading(col, text=col)\n",
    "            self.tree.column(col, width=90)\n",
    "        self.tree.pack(side=tk.LEFT, fill=tk.Y)\n",
    "        \n",
    "        scrollbar = ttk.Scrollbar(self.frame_table, orient=tk.VERTICAL, command=self.tree.yview)\n",
    "        self.tree.configure(yscroll=scrollbar.set)\n",
    "        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)\n",
    "        \n",
    "        # Graph (Right)\n",
    "        self.frame_graph = ttk.Frame(self.frame_bottom)\n",
    "        self.frame_graph.pack(side=tk.RIGHT, fill=tk.BOTH, expand=True)\n",
    "        \n",
    "        self.fig, self.ax = plt.subplots(figsize=(5, 4), tight_layout=True)\n",
    "        self.canvas = FigureCanvasTkAgg(self.fig, master=self.frame_graph)\n",
    "        self.canvas.get_tk_widget().pack(fill=tk.BOTH, expand=True)\n",
    "\n",
    "    def toggle_inputs(self, event=None):\n",
    "        if self.method_var.get() == \"Newton-Raphson\":\n",
    "            self.entry_xu.config(state=\"disabled\")\n",
    "        else:\n",
    "            self.entry_xu.config(state=\"normal\")\n",
    "\n",
    "    def calculate(self):\n",
    "        expr = self.entry_func.get()\n",
    "        method = self.method_var.get()\n",
    "        \n",
    "        try:\n",
    "            xl = float(self.entry_xl.get())\n",
    "            tol = float(self.entry_tol.get())\n",
    "            max_iter = int(self.entry_iter.get())\n",
    "            \n",
    "            if method == \"Bisection\":\n",
    "                xu = float(self.entry_xu.get())\n",
    "                root_val, hist = bisection(expr, xl, xu, tol, max_iter)\n",
    "            elif method == \"False Position\":\n",
    "                xu = float(self.entry_xu.get())\n",
    "                root_val, hist = false_position(expr, xl, xu, tol, max_iter)\n",
    "            elif method == \"Secant\":\n",
    "                xu = float(self.entry_xu.get())\n",
    "                root_val, hist = secant(expr, xl, xu, tol, max_iter)\n",
    "            elif method == \"Newton-Raphson\":\n",
    "                root_val, hist = newton_raphson(expr, xl, tol, max_iter)\n",
    "                \n",
    "            self.update_table(hist)\n",
    "            # Pass method name and full history to plotting function\n",
    "            self.update_graph(expr, root_val, method, hist)\n",
    "            \n",
    "        except Exception as e:\n",
    "            messagebox.showerror(\"Error\", str(e))\n",
    "\n",
    "    def update_table(self, history):\n",
    "        for item in self.tree.get_children():\n",
    "            self.tree.delete(item)\n",
    "        for row in history:\n",
    "            # Table only shows first 4 standard values\n",
    "            table_data = row[:4]\n",
    "            formatted_row = (table_data[0], f\"{table_data[1]:.6f}\", f\"{table_data[2]:.6f}\", f\"{table_data[3]:.6f}\")\n",
    "            self.tree.insert(\"\", tk.END, values=formatted_row)\n",
    "\n",
    "    def update_graph(self, expr, root_val, method, hist):\n",
    "        \"\"\"Plots function, root, and geometric interpretation of iterations.\"\"\"\n",
    "        self.ax.clear()\n",
    "        \n",
    "        # --- 1. Determine Smart Plotting Range ---\n",
    "        x_points = [root_val]\n",
    "        if hist:\n",
    "            # Add initial points from the first iteration history to set the view\n",
    "            if method == \"Bisection\": x_points.extend([hist[0][4], hist[0][5]])\n",
    "            elif method == \"False Position\": x_points.extend([hist[0][4], hist[0][6]])\n",
    "            elif method == \"Newton-Raphson\": x_points.append(hist[0][4])\n",
    "            elif method == \"Secant\": x_points.extend([hist[0][4], hist[0][6]])\n",
    "            \n",
    "        x_min, x_max = min(x_points), max(x_points)\n",
    "        span = x_max - x_min if x_max != x_min else 1.0\n",
    "        x_start, x_end = x_min - span*0.5, x_max + span*0.5\n",
    "        \n",
    "        # --- 2. Plot Main Function & Axes ---\n",
    "        x_vals = np.linspace(x_start, x_end, 500)\n",
    "        y_vals = [evaluate_function(expr, x) for x in x_vals]\n",
    "        \n",
    "        self.ax.plot(x_vals, y_vals, label=f\"f(x) = {expr}\", color='steelblue', linewidth=2)\n",
    "        self.ax.axhline(0, color='black', linewidth=0.8)\n",
    "        self.ax.axvline(0, color='black', linewidth=0.8)\n",
    "        \n",
    "        # --- 3. Plot Geometric Interpretation (First 2 Iterations) ---\n",
    "        colors = ['green', 'purple'] # Colors for iter 1 & 2\n",
    "        num_to_show = min(len(hist), 2)\n",
    "        \n",
    "        for i in range(num_to_show):\n",
    "            color = colors[i]\n",
    "            row = hist[i]\n",
    "            label_prefix = f\"Iter {i+1}\" if i==0 else \"\"\n",
    "            \n",
    "            if method == \"Newton-Raphson\":\n",
    "                # row = (iter, xi_next, f(xi_next), err, xi, fxi, dfxi)\n",
    "                xi, fxi = row[4], row[5]\n",
    "                xi_next = row[1]\n",
    "                # Draw tangent line segment\n",
    "                self.ax.plot([xi, xi_next], [fxi, 0], color=color, linestyle='--', linewidth=1.5, label=f\"{label_prefix} Tangent\")\n",
    "                # Draw vertical drop to new point\n",
    "                self.ax.plot([xi_next, xi_next], [0, evaluate_function(expr, xi_next)], color=color, linestyle=':', linewidth=1)\n",
    "                self.ax.scatter([xi], [fxi], color=color, marker='o') # Start point\n",
    "\n",
    "            elif method in [\"False Position\", \"Secant\"]:\n",
    "                # FP: row = (iter, xr, fxr, err, xl, fl, xu, fu)\n",
    "                # Secant: row = (iter, x_next, f(x_next), err, x0, fx0, x1, fx1)\n",
    "                xa, fxa = row[4], row[5]\n",
    "                xb, fxb = row[6], row[7]\n",
    "                xr = row[1] # The new x-intercept\n",
    "                \n",
    "                # Draw secant line segment connecting the points\n",
    "                self.ax.plot([xa, xb], [fxa, fxb], color=color, linestyle='--', linewidth=1.5, label=f\"{label_prefix} Secant\")\n",
    "                # Draw line from a point to the intercept to show the projection\n",
    "                self.ax.plot([xb, xr], [fxb, 0], color=color, linestyle='--', linewidth=1.5)\n",
    "                # Draw vertical drop\n",
    "                self.ax.plot([xr, xr], [0, evaluate_function(expr, xr)], color=color, linestyle=':', linewidth=1)\n",
    "                self.ax.scatter([xa, xb], [fxa, fxb], color=color, marker='o') # Points on curve\n",
    "                \n",
    "            elif method == \"Bisection\":\n",
    "                # row = (iter, xr, fxr, err, xl, xu)\n",
    "                xl, xu, xr = row[4], row[5], row[1]\n",
    "                # Draw vertical bracket lines\n",
    "                self.ax.vlines([xl, xu], ymin=min(y_vals), ymax=max(y_vals), color=color, linestyle=':', label=f\"{label_prefix} Bracket\")\n",
    "                # Mark midpoint on x-axis\n",
    "                self.ax.scatter([xr], [0], color=color, marker='|', s=100, linewidth=2)\n",
    "\n",
    "        # --- 4. Finalize Graph ---\n",
    "        self.ax.scatter([root_val], [evaluate_function(expr, root_val)], color='red', marker='*', s=180, zorder=10, label=f\"Final Root ~ {root_val:.4f}\")\n",
    "        self.ax.set_title(f\"{method} Method - Geometric Interpretation\")\n",
    "        self.ax.set_xlabel(\"x\")\n",
    "        self.ax.set_ylabel(\"f(x)\")\n",
    "        self.ax.legend(loc='best', fontsize='small')\n",
    "        self.ax.grid(True, linestyle='--', alpha=0.5)\n",
    "        \n",
    "        self.canvas.draw()\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    root = tk.Tk()\n",
    "    app = NumericalMethodsApp(root)\n",
    "    root.mainloop()"
   ]
